+  <body>
+    <main class="shell">
+      <section class="hero" aria-labelledby="page-title">
+        <div>
+          <p class="eyebrow">Vibe Support</p>
+          <h1 id="page-title">Find the right answer fast</h1>
+          <p class="intro">Search account, billing, security, integration, and workspace questions from one focused help center.</p>
